<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<style>
/* ======== 扫码测试取景框 ======== */
.scan-test-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: #0a0a0a;
  flex-direction: column;
  align-items: center;
}
.scan-test-overlay.show { display: flex; }
.scan-test-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 12px 16px;
  color: #fff;
  flex-shrink: 0;
}
.scan-test-topbar .title { font-size: 17px; font-weight: 600; }
.scan-test-topbar .close-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: none; color: #fff; font-size: 20px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.scan-test-viewport {
  position: relative;
  width: 280px; height: 280px;
  flex-shrink: 0;
  margin-top: 8vh;
}
.scan-test-viewport video {
  width: 100%; height: 100%;
  object-fit: cover;
  border-radius: 8px;
}
.scan-test-line {
  position: absolute; left: 4px; right: 4px; height: 2px;
  background: linear-gradient(90deg, transparent 0%, rgba(74,144,217,0.3) 15%, #4A90D9 50%, rgba(74,144,217,0.3) 85%, transparent 100%);
  box-shadow: 0 0 8px rgba(74,144,217,0.6);
  border-radius: 1px;
  animation: scanTestMove 2.2s cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
  z-index: 5; pointer-events: none;
}
@keyframes scanTestMove {
  0% { top: 8px; opacity: 0; }
  10% { opacity: 1; }
  80% { opacity: 1; }
  100% { top: calc(100% - 10px); opacity: 0; }
}
.scan-test-corner {
  position: absolute; width: 24px; height: 24px; z-index: 6; pointer-events: none;
}
.scan-test-corner::before, .scan-test-corner::after {
  content: ''; position: absolute; background: #4A90D9; border-radius: 2px;
}
.scan-test-corner::before { width: 24px; height: 3px; top: 0; left: 0; }
.scan-test-corner::after { width: 3px; height: 24px; top: 0; left: 0; }
.scan-test-corner-tl { top: -1px; left: -1px; }
.scan-test-corner-tr { top: -1px; right: -1px; }
.scan-test-corner-tr::before, .scan-test-corner-tr::after { left: auto; right: 0; }
.scan-test-corner-bl { bottom: -1px; left: -1px; }
.scan-test-corner-bl::before, .scan-test-corner-bl::after { top: auto; bottom: 0; }
.scan-test-corner-br { bottom: -1px; right: -1px; }
.scan-test-corner-br::before, .scan-test-corner-br::after { top: auto; bottom: 0; left: auto; right: 0; }
.scan-test-mask {
  position: absolute; background: rgba(10,10,10,0.55); pointer-events: none; z-index: 3;
}
.scan-test-status {
  flex-shrink: 0; padding: 12px 24px; text-align: center;
  font-size: 13px; color: #a0a0b0; min-height: 42px;
  display: flex; align-items: center; justify-content: center;
}
.scan-test-actions {
  padding: 0 24px 24px; width: 100%;
}
.scan-test-actions .confirm-btn {
  width: 100%; padding: 14px; background: #4A90D9; color: #fff;
  border: none; border-radius: 10px; font-size: 16px; font-weight: 600; cursor: pointer;
  transition: all 0.15s;
}
.scan-test-actions .confirm-btn:active { transform: scale(0.97); }
.scan-test-actions .retry-btn {
  display: block; width: 100%; margin-top: 10px; padding: 10px;
  background: transparent; color: #999;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 10px; font-size: 14px; cursor: pointer;
}
.scan-test-hint {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 0 24px; text-align: center; min-height: 80px;
}
.scan-test-hint .hint-text { color: #c0c0c8; font-size: 14px; line-height: 1.8; }
.scan-test-hint .hint-icon { font-size: 28px; margin-bottom: 10px; opacity: 0.6; }
</style>

<div class="flex-between mb-16">
  <div style="display: flex; align-items: center; gap: 12px;">
    <a href="/admin/dashboard" class="btn btn-secondary btn-sm">&larr; 返回首页</a>
    <h2 style="font-size: 20px; margin: 0;">账号管理</h2>
  </div>
  <div style="display: flex; gap: 8px;">
    <button class="btn btn-secondary btn-sm" onclick="checkAllCookies()">批量检测</button>
    <button class="btn btn-secondary btn-sm" onclick="fetchAllVip()" id="fetchVipBtn">批量抓取账号信息</button>
    <a href="/admin/accounts/add" class="btn btn-primary">+ 添加账号</a>
  </div>
</div>

<!-- 筛选栏 -->
<div class="card">
  <form method="GET" action="/admin/accounts" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
    <input type="text" name="search" class="form-control" placeholder="搜索昵称或手机号..." value="<%= typeof search !== 'undefined' ? search : '' %>" style="max-width: 260px;">
    <select name="status" class="form-control" style="max-width: 140px;">
      <option value="all" <%= status === 'all' || !status ? 'selected' : '' %>>全部状态</option>
      <option value="valid" <%= status === 'valid' ? 'selected' : '' %>>Cookie 有效</option>
      <option value="expired" <%= status === 'expired' ? 'selected' : '' %>>Cookie 过期</option>
      <option value="unknown" <%= status === 'unknown' ? 'selected' : '' %>>状态未知</option>
    </select>
    <button type="submit" class="btn btn-primary btn-sm">筛选</button>
    <% if (search || (status && status !== 'all')) { %>
      <a href="/admin/accounts" class="btn btn-secondary btn-sm">清除</a>
    <% } %>
  </form>
</div>

<!-- 账号列表 -->
<% if (accounts.length === 0) { %>
<div class="card">
  <div class="empty-state">
    <div class="empty-icon">&#128230;</div>
    <p>还没有添加任何账号</p>
    <a href="/admin/accounts/add" class="btn btn-primary mt-16">添加第一个账号</a>
  </div>
</div>
<% } else { %>

<!-- 批量操作栏 -->
<div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px;">
  <button class="btn btn-sm btn-secondary" onclick="selectExpired()">全选已停用/过期</button>
  <button class="btn btn-sm btn-secondary" onclick="selectAll()">全选所有</button>
  <button class="btn btn-sm btn-secondary" onclick="clearSelection()">取消全选</button>
  <span style="flex:1;"></span>
  <span id="selectedCount" style="font-size: 13px; color: #999;"></span>
  <button class="btn btn-sm btn-danger" onclick="batchDelete()">批量删除选中</button>
</div>

<div class="card" style="padding: 0;">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th style="width: 40px;">
            <input type="checkbox" id="selectAllCheckbox" onclick="toggleSelectAll(this)" title="全选/取消全选">
          </th>
          <th>昵称</th>
          <th>备注</th>
          <th>手机号</th>
          <th>会员类型</th>
          <th>到期时间</th>
          <th>Cookie 状态</th>
          <th>更新时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% accounts.forEach(function(acc) { %>
        <tr>
          <td>
            <input type="checkbox" class="account-checkbox" data-id="<%= acc.id %>" data-status="<%= acc.cookie_status %>" onchange="updateSelection()">
          </td>
          <td><strong><%= acc.nickname %></strong>
            <% if (acc.is_paused) { %><span class="tag tag-danger" style="font-size:10px;margin-left:4px;">已暂停</span><% } %>
          </td>
          <td style="font-size:12px;color:#666;"><%= acc.notes || '--' %></td>
          <td><%= maskPhone(acc.phone) %></td>
          <td>
            <% if (acc.vip_type === 'svip') { %>
              <span class="tag tag-warning">SVIP</span>
            <% } else if (acc.vip_type === 'vip') { %>
              <span class="tag tag-default">VIP</span>
            <% } else if (acc.vip_type === 'normal') { %>
              <span class="tag tag-default">普通</span>
            <% } else { %>
              --
            <% } %>
          </td>
          <td>
            <% if (acc.vip_expire_date) { %>
              <%= acc.vip_expire_date %>
            <% } else { %>
              --
            <% } %>
          </td>
          <td id="status-<%= acc.id %>">
            <% if (acc.cookie_status === 'valid') { %>
              <span class="tag tag-success">有效</span>
            <% } else if (acc.cookie_status === 'expired') { %>
              <span class="tag tag-danger">过期</span>
            <% } else { %>
              <span class="tag tag-default">未知</span>
            <% } %>
          </td>
          <td><%= acc.updated_at ? acc.updated_at.slice(0, 16) : '--' %></td>
          <td>
            <a href="/admin/accounts/<%= acc.id %>" class="btn btn-sm btn-secondary">详情</a>
            <button class="btn btn-sm btn-secondary" onclick="checkCookie(<%= acc.id %>)" id="btn-<%= acc.id %>">检测</button>
            <button class="btn btn-sm btn-secondary" onclick="scanTest(<%= acc.id %>, '<%= acc.nickname %>')" id="scanbtn-<%= acc.id %>">扫码测试</button>
            <button class="btn btn-sm btn-secondary" onclick="togglePause(<%= acc.id %>)" id="pause-<%= acc.id %>"><%= acc.is_paused ? '恢复' : '暂停' %></button>
            <button class="btn btn-sm btn-danger" onclick="deleteAccount(<%= acc.id %>, '<%= acc.nickname %>')">删除</button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- ======== 扫码测试取景框 ======== -->
<div class="scan-test-overlay" id="scanTestOverlay">
  <div class="scan-test-topbar">
    <span class="title">扫码测试登录</span>
    <button class="close-btn" onclick="closeScanTest()">&times;</button>
  </div>
  <div class="scan-test-viewport" id="scanTestViewport">
    <video id="scanTestVideo" autoplay playsinline></video>
    <canvas id="scanTestCanvas" style="display:none;"></canvas>
    <div class="scan-test-corner scan-test-corner-tl"></div>
    <div class="scan-test-corner scan-test-corner-tr"></div>
    <div class="scan-test-corner scan-test-corner-bl"></div>
    <div class="scan-test-corner scan-test-corner-br"></div>
    <div class="scan-test-line" id="scanTestLine"></div>
  </div>
  <div class="scan-test-status" id="scanTestStatus">正在启动摄像头...</div>
  <div class="scan-test-actions" id="scanTestActions">
    <div class="scan-test-hint" id="scanTestHint">
      <div class="hint-icon">&#128269;</div>
      <div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div>
    </div>
  </div>
</div>

<script>
// === 选择功能 ===
function updateSelection() {
  var checked = document.querySelectorAll('.account-checkbox:checked');
  var count = checked.length;
  document.getElementById('selectedCount').textContent = count > 0 ? '已选择 ' + count + ' 个账号' : '';

  var all = document.querySelectorAll('.account-checkbox');
  var selectAll = document.getElementById('selectAllCheckbox');
  selectAll.checked = all.length > 0 && checked.length === all.length;
  selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
}

function toggleSelectAll(el) {
  var checkboxes = document.querySelectorAll('.account-checkbox');
  checkboxes.forEach(function(cb) { cb.checked = el.checked; });
  updateSelection();
}

function selectAll() {
  document.querySelectorAll('.account-checkbox').forEach(function(cb) { cb.checked = true; });
  updateSelection();
}

function clearSelection() {
  document.querySelectorAll('.account-checkbox').forEach(function(cb) { cb.checked = false; });
  updateSelection();
}

function selectExpired() {
  document.querySelectorAll('.account-checkbox').forEach(function(cb) {
    cb.checked = cb.dataset.status !== 'valid';
  });
  updateSelection();
}

function getSelectedIds() {
  var ids = [];
  document.querySelectorAll('.account-checkbox:checked').forEach(function(cb) {
    ids.push(parseInt(cb.dataset.id));
  });
  return ids;
}

// === 批量删除 ===
async function batchDelete() {
  var ids = getSelectedIds();
  if (ids.length === 0) {
    alert('请先勾选要删除的账号');
    return;
  }

  // 查询所有选中账号的依赖链接
  var totalPool = 0, totalSolo = 0;
  for (var id of ids) {
    try {
      var depRes = await fetch('/admin/api/accounts/' + id + '/dependent-links');
      var dep = await depRes.json();
      totalPool += dep.poolCount || 0;
      totalSolo += dep.soloCount || 0;
    } catch(e) {}
  }

  var msg = '确定要删除选中的 ' + ids.length + ' 个账号吗？';
  if (totalPool > 0) msg += '\n\n⚠ ' + totalPool + ' 个共享链接将自动切换账号。';
  if (totalSolo > 0) msg += '\n\n⚠ ' + totalSolo + ' 个独享链接将失效。';
  msg += '\n\n删除后可在数据库中恢复。';

  if (!confirm(msg)) return;

  try {
    var res = await fetch('/admin/api/accounts/batch-delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: ids })
    });
    var data = await res.json();
    if (data.success) {
      alert(data.message);
      location.reload();
    } else {
      alert(data.message);
    }
  } catch(e) {
    alert('批量删除失败: ' + (e.message || e));
  }
}

// === 单账号 Cookie 检测 ===
async function checkCookie(id) {
  var btn = document.getElementById('btn-' + id);
  var statusCell = document.getElementById('status-' + id);
  btn.disabled = true;
  btn.textContent = '检测中...';
  statusCell.innerHTML = '<span class="tag tag-default">检测中...</span>';

  try {
    var res = await fetch('/admin/api/accounts/' + id + '/check-cookie', { method: 'POST' });
    var data = await res.json();
    if (data.success && data.result) {
      var r = data.result;
      var html = r.valid
        ? '<span class="tag tag-success">有效</span>' + (r.username ? ' <small>' + r.username + '</small>' : '') + (r.vipType ? ' <small>' + r.vipType.toUpperCase() + '</small>' : '')
        : '<span class="tag tag-danger">过期</span>';
      if (data.poolLinksReassigned > 0) {
        html += ' <small style="color:#FAAD14;">(' + data.poolLinksReassigned + ' 链接已切换)</small>';
        alert('检测到 Cookie 过期，已自动将 ' + data.poolLinksReassigned + ' 个关联链接切换到其他账号');
      }
      statusCell.innerHTML = html;
    } else {
      statusCell.innerHTML = '<span class="tag tag-danger">检测失败</span>';
      alert(data.message || '检测失败');
    }
  } catch(e) {
    statusCell.innerHTML = '<span class="tag tag-danger">网络错误</span>';
  }
  btn.disabled = false;
  btn.textContent = '检测';
}

// === 批量检测 ===
async function checkAllCookies() {
  if (!confirm('将逐个检测所有账号的 Cookie 有效性，可能需要几秒到几十秒，确定继续？')) return;

  var buttons = document.querySelectorAll('button[id^="btn-"]');
  buttons.forEach(function(b) { b.disabled = true; b.textContent = '...'; });

  try {
    var res = await fetch('/admin/api/accounts/check-all-cookies', { method: 'POST' });
    var data = await res.json();
    if (data.success && data.results) {
      data.results.forEach(function(r) {
        var cell = document.getElementById('status-' + r.id);
        if (cell) {
          var html = r.valid
            ? '<span class="tag tag-success">有效</span>' + (r.username ? ' <small>' + r.username + '</small>' : '') + (r.vipType ? ' <small>' + r.vipType.toUpperCase() + '</small>' : '')
            : '<span class="tag tag-danger">过期</span>' + (r.raw ? ' <br><small>' + r.raw + '</small>' : '');
          if (r.reassignedLinks > 0) {
            html += ' <small style="color:#FAAD14;">(' + r.reassignedLinks + ' 链接已切换)</small>';
          }
          cell.innerHTML = html;
        }
      });
      var validCount = data.results.filter(function(r) { return r.valid; }).length;
      var msg = '检测完成：' + validCount + ' 个有效，' + (data.results.length - validCount) + ' 个过期';
      if (data.poolLinksReassigned > 0) {
        msg += '\n\n' + data.poolLinksReassigned + ' 个过期账号的池链接已自动切换。';
      }
      alert(msg);
    }
  } catch(e) {
    alert('批量检测失败: ' + (e.message || e));
  }
  buttons.forEach(function(b) { b.disabled = false; b.textContent = '检测'; });
}

// === 批量抓取账号信息 ===
async function fetchAllVip() {
  if (!confirm('将逐个抓取所有账号的会员信息，可能需要几秒到几十秒，确定继续？')) return;

  var btn = document.getElementById('fetchVipBtn');
  btn.disabled = true;
  btn.textContent = '抓取中...';

  try {
    var res = await fetch('/admin/api/accounts/fetch-all-vip', { method: 'POST' });
    var data = await res.json();
    if (data.success && data.results) {
      // 更新表格中的会员类型和到期时间
      data.results.forEach(function(r) {
        if (!r.ok) return;
        // 找到对应行并更新显示
        var rows = document.querySelectorAll('table tbody tr');
        rows.forEach(function(row) {
          var link = row.querySelector('a[href="/admin/accounts/' + r.id + '"]');
          if (!link) return;
          // 更新会员类型（第5列）
          var cells = row.querySelectorAll('td');
          if (cells.length >= 5) {
            if (r.vipType === 'svip') cells[4].innerHTML = '<span class="tag tag-warning">SVIP</span>';
            else if (r.vipType === 'vip') cells[4].innerHTML = '<span class="tag tag-default">VIP</span>';
            else if (r.vipType === 'normal') cells[4].innerHTML = '<span class="tag tag-default">普通</span>';
          }
          // 更新到期时间（第6列）
          if (cells.length >= 6 && r.expireDate) {
            cells[5].textContent = r.expireDate;
          }
          // 更新昵称（第2列）
          if (cells.length >= 2 && r.nickname) {
            var strong = cells[1].querySelector('strong');
            if (strong) strong.textContent = r.nickname;
          }
        });
      });
      alert('抓取完成：已更新 ' + data.updatedCount + ' / ' + data.total + ' 个账号');
    } else {
      alert('抓取失败: ' + (data.message || '未知错误'));
    }
  } catch(e) {
    alert('抓取出错: ' + (e.message || e));
  }
  btn.disabled = false;
  btn.textContent = '批量抓取账号信息';
}

// === 暂停/恢复 ===
async function togglePause(id) {
  var res = await fetch('/admin/api/accounts/' + id + '/toggle-pause', { method: 'POST' });
  var data = await res.json();
  if (data.success) {
    location.reload();
  } else {
    alert(data.message);
  }
}

// === 单账号删除 ===
async function deleteAccount(id, nickname) {
  // 先查询依赖链接
  var depRes = await fetch('/admin/api/accounts/' + id + '/dependent-links');
  var dep = await depRes.json();

  var msg = '确定要删除账号「' + nickname + '」吗？';
  if (dep.poolCount > 0) {
    msg += '\n\n⚠ 该账号关联了 ' + dep.poolCount + ' 个共享链接，删除后将自动切换到其他账号。';
  }
  if (dep.soloCount > 0) {
    msg += '\n\n⚠ 该账号关联了 ' + dep.soloCount + ' 个独享链接，删除后这些链接将失效。';
  }
  msg += '\n\n删除后可在数据库中恢复。';

  if (!confirm(msg)) return;

  var res = await fetch('/admin/api/accounts/' + id + '/delete', { method: 'POST' });
  var data = await res.json();
  if (data.success) {
    alert(data.message);
    location.reload();
  } else {
    alert(data.message);
  }
}

// ======== 扫码测试登录 ========
var scanTestStream = null;
var scanTestTimer = null;
var scanTestCapturedQR = '';
var scanTestAccountId = null;
var scanTestAccountName = '';
var scanTestConfirming = false;

async function scanTest(id, nickname) {
  scanTestAccountId = id;
  scanTestAccountName = nickname;
  scanTestCapturedQR = '';
  scanTestConfirming = false;

  var overlay = document.getElementById('scanTestOverlay');
  overlay.classList.add('show');
  document.getElementById('scanTestStatus').textContent = '正在启动摄像头...';
  document.getElementById('scanTestHint').style.display = 'flex';
  document.getElementById('scanTestActions').innerHTML =
    '<div class="scan-test-hint" id="scanTestHint"><div class="hint-icon">&#128269;</div><div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div></div>';

  try {
    scanTestStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } }
    });
    var video = document.getElementById('scanTestVideo');
    video.srcObject = scanTestStream;
    await video.play();
    document.getElementById('scanTestStatus').textContent = '测试账号：' + nickname + ' — 请扫描二维码';
    scanTestLoop();
  } catch (err) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">摄像头启动失败</span><br><small style="color:#999;">请确保使用HTTPS访问并授予摄像头权限</small>';
  }
}

function scanTestLoop() {
  if (scanTestCapturedQR || scanTestConfirming || !document.getElementById('scanTestOverlay').classList.contains('show')) return;
  var video = document.getElementById('scanTestVideo');
  if (video.readyState < video.HAVE_ENOUGH_DATA) { scanTestTimer = requestAnimationFrame(scanTestLoop); return; }
  var canvas = document.getElementById('scanTestCanvas');
  var w = video.videoWidth || 640, h = video.videoHeight || 480;
  canvas.width = w; canvas.height = h;
  var ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0, w, h);
  var imageData = ctx.getImageData(0, 0, w, h);
  try {
    var code = jsQR(imageData.data, w, h, { inversionAttempts: 'dontInvert' });
    if (code && code.data) {
      scanTestCapturedQR = code.data;
      stopScanTestCamera();
      showScanTestConfirm();
      return;
    }
  } catch(e) {}
  scanTestTimer = requestAnimationFrame(scanTestLoop);
}

function stopScanTestCamera() {
  if (scanTestTimer) { cancelAnimationFrame(scanTestTimer); scanTestTimer = null; }
  if (scanTestStream) { scanTestStream.getTracks().forEach(function(t) { t.stop(); }); scanTestStream = null; }
}

function closeScanTest() {
  stopScanTestCamera();
  document.getElementById('scanTestOverlay').classList.remove('show');
  scanTestCapturedQR = '';
  scanTestConfirming = false;
  scanTestAccountId = null;
}

function showScanTestConfirm() {
  document.getElementById('scanTestStatus').innerHTML =
    '<span style="color:#52C41A;">已检测到二维码</span>';
  document.getElementById('scanTestActions').innerHTML =
    '<button class="confirm-btn" onclick="doScanTest()">确认测试登录</button>' +
    '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>';
}

async function doScanTest() {
  scanTestConfirming = true;
  document.getElementById('scanTestStatus').textContent = '正在测试登录...';
  document.getElementById('scanTestActions').innerHTML = '';

  var btn = document.getElementById('scanbtn-' + scanTestAccountId);
  if (btn) { btn.disabled = true; btn.textContent = '测试中...'; }

  try {
    var res = await fetch('/admin/api/accounts/' + scanTestAccountId + '/scan-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ qrContent: scanTestCapturedQR })
    });
    var data = await res.json();

    if (data.success) {
      var extra = data.rotated
        ? '<br><small style="color:#FAAD14;">已自动切换至备用账号：' + data.usedAccount.nickname + '（' + (data.usedAccount.vipType === 'svip' ? 'SVIP' : data.usedAccount.vipType === 'vip' ? 'VIP' : '普通') + '）</small>'
        : '<br><small style="color:#52C41A;">账号「' + data.usedAccount.nickname + '」Cookie有效，登录正常</small>';
      document.getElementById('scanTestStatus').innerHTML =
        '<span style="color:#52C41A;font-size:16px;">登录成功！</span>' + extra;
      document.getElementById('scanTestActions').innerHTML =
        '<button class="retry-btn" onclick="resetScanTest()">再次测试</button>' +
        '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';

      // 更新列表中该行的 Cookie 状态
      if (!data.rotated) {
        var statusCell = document.getElementById('status-' + scanTestAccountId);
        if (statusCell) {
          statusCell.innerHTML = '<span class="tag tag-success">有效</span> <small>' + data.usedAccount.vipType.toUpperCase() + '</small>';
        }
      }
    } else {
      document.getElementById('scanTestStatus').innerHTML =
        '<span style="color:#FF4D4F;">登录失败</span><br><small style="color:#999;">' + (data.message || '未知错误') + '</small>';
      document.getElementById('scanTestActions').innerHTML =
        '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>' +
        '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';
    }
  } catch (e) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">网络错误</span><br><small style="color:#999;">' + (e.message || e) + '</small>';
    document.getElementById('scanTestActions').innerHTML =
      '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>' +
      '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';
  }
  scanTestConfirming = false;
  if (btn) { btn.disabled = false; btn.textContent = '扫码测试'; }
}

async function resetScanTest() {
  scanTestCapturedQR = '';
  scanTestConfirming = false;
  document.getElementById('scanTestStatus').textContent = '正在重新启动摄像头...';
  document.getElementById('scanTestActions').innerHTML =
    '<div class="scan-test-hint" id="scanTestHint"><div class="hint-icon">&#128269;</div><div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div></div>';

  try {
    scanTestStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } }
    });
    var video = document.getElementById('scanTestVideo');
    video.srcObject = scanTestStream;
    await video.play();
    document.getElementById('scanTestStatus').textContent = '测试账号：' + scanTestAccountName + ' — 请扫描二维码';
    scanTestLoop();
  } catch (err) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">摄像头启动失败</span><br><small style="color:#999;">' + (err.message || err) + '</small>';
  }
}
</script>
