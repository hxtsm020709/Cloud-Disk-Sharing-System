<script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
<style>
/* ======== 扫码测试取景框 ======== */
.scan-test-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: #0a0a0a;
  flex-direction: column;
  align-items: center;
}
.scan-test-overlay.show { display: flex; }
.scan-test-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 12px 16px;
  color: #fff;
  flex-shrink: 0;
}
.scan-test-topbar .title { font-size: 17px; font-weight: 600; }
.scan-test-topbar .close-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: none; color: #fff; font-size: 20px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.scan-test-viewport {
  position: relative;
  width: 280px; height: 280px;
  flex-shrink: 0;
  margin-top: 8vh;
}
.scan-test-viewport video {
  width: 100%; height: 100%;
  object-fit: cover;
  border-radius: 8px;
}
.scan-test-line {
  position: absolute; left: 4px; right: 4px; height: 2px;
  background: linear-gradient(90deg, transparent 0%, rgba(74,144,217,0.3) 15%, #4A90D9 50%, rgba(74,144,217,0.3) 85%, transparent 100%);
  box-shadow: 0 0 8px rgba(74,144,217,0.6);
  border-radius: 1px;
  animation: scanTestMove 2.2s cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
  z-index: 5; pointer-events: none;
}
@keyframes scanTestMove {
  0% { top: 8px; opacity: 0; }
  10% { opacity: 1; }
  80% { opacity: 1; }
  100% { top: calc(100% - 10px); opacity: 0; }
}
.scan-test-corner {
  position: absolute; width: 24px; height: 24px; z-index: 6; pointer-events: none;
}
.scan-test-corner::before, .scan-test-corner::after {
  content: ''; position: absolute; background: #4A90D9; border-radius: 2px;
}
.scan-test-corner::before { width: 24px; height: 3px; top: 0; left: 0; }
.scan-test-corner::after { width: 3px; height: 24px; top: 0; left: 0; }
.scan-test-corner-tl { top: -1px; left: -1px; }
.scan-test-corner-tr { top: -1px; right: -1px; }
.scan-test-corner-tr::before, .scan-test-corner-tr::after { left: auto; right: 0; }
.scan-test-corner-bl { bottom: -1px; left: -1px; }
.scan-test-corner-bl::before, .scan-test-corner-bl::after { top: auto; bottom: 0; }
.scan-test-corner-br { bottom: -1px; right: -1px; }
.scan-test-corner-br::before, .scan-test-corner-br::after { top: auto; bottom: 0; left: auto; right: 0; }
.scan-test-mask {
  position: absolute; background: rgba(10,10,10,0.55); pointer-events: none; z-index: 3;
}
.scan-test-status {
  flex-shrink: 0; padding: 12px 24px; text-align: center;
  font-size: 13px; color: #a0a0b0; min-height: 42px;
  display: flex; align-items: center; justify-content: center;
}
.scan-test-actions {
  padding: 0 24px 24px; width: 100%;
}
.scan-test-actions .confirm-btn {
  width: 100%; padding: 14px; background: #4A90D9; color: #fff;
  border: none; border-radius: 10px; font-size: 16px; font-weight: 600; cursor: pointer;
  transition: all 0.15s;
}
.scan-test-actions .confirm-btn:active { transform: scale(0.97); }
.scan-test-actions .retry-btn {
  display: block; width: 100%; margin-top: 10px; padding: 10px;
  background: transparent; color: #999;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 10px; font-size: 14px; cursor: pointer;
}
.scan-test-hint {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 0 24px; text-align: center; min-height: 80px;
}
.scan-test-hint .hint-text { color: #c0c0c8; font-size: 14px; line-height: 1.8; }
.scan-test-hint .hint-icon { font-size: 28px; margin-bottom: 10px; opacity: 0.6; }
</style>

<div class="flex-between" style="margin-bottom: 20px;">
  <div style="display: flex; align-items: center; gap: 12px;">
    <a href="/admin/accounts" class="btn btn-secondary btn-sm">&larr; 返回账号列表</a>
    <h2 style="font-size: 20px; margin: 0;">账号详情 — <%= account.nickname %></h2>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">

  <!-- 左侧：基本信息 -->
  <div class="card">
    <div class="card-title">基本信息</div>
    <form id="editForm">
      <input type="hidden" name="id" value="<%= account.id %>">
      <div class="form-group">
        <label>昵称</label>
        <input type="text" name="nickname" class="form-control" value="<%= account.nickname %>" required>
      </div>
      <div class="form-group">
        <label>手机号</label>
        <input type="text" name="phone" class="form-control" value="<%= account.phone || '' %>">
      </div>
      <div class="form-group">
        <label>会员类型</label>
        <select name="vip_type" class="form-control">
          <option value="normal" <%= account.vip_type === 'normal' ? 'selected' : '' %>>普通账号</option>
          <option value="vip" <%= account.vip_type === 'vip' ? 'selected' : '' %>>VIP（普通会员）</option>
          <option value="svip" <%= account.vip_type === 'svip' ? 'selected' : '' %>>SVIP（超级会员）</option>
        </select>
      </div>
      <div class="form-group">
        <label>会员到期日期</label>
        <input type="date" name="vip_expire_date" class="form-control" value="<%= account.vip_expire_date || '' %>">
      </div>
      <div class="form-group">
        <label>备注</label>
        <input type="text" name="notes" class="form-control" value="<%= account.notes || '' %>">
      </div>
      <button type="submit" class="btn btn-primary">保存修改</button>
      <span id="editMsg" style="margin-left: 12px; font-size: 13px;"></span>
    </form>
  </div>

  <!-- 右侧：Cookie + 操作 -->
  <div>
    <!-- Cookie 状态 -->
    <div class="card">
      <div class="card-title">账号信息</div>
      <div style="margin-bottom: 12px;">
        <span style="color: #666; font-size: 13px;">当前 Cookie：</span>
        <code style="background:#F5F7FA; padding: 2px 8px; border-radius: 4px; font-size: 12px; word-break: break-all;"><%= cookiePreview %></code>
        <% if (cookieFull) { %>
        <button class="btn btn-sm btn-secondary" onclick="copyFullCookie()" style="margin-left: 6px; flex-shrink: 0;">复制</button>
        <span id="cookieCopyMsg" style="margin-left: 4px; font-size: 11px;"></span>
        <% } %>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="color: #666; font-size: 13px;">状态：</span>
        <span id="cookieStatus">
        <% if (account.cookie_status === 'valid') { %>
          <span class="tag tag-success">有效</span>
        <% } else if (account.cookie_status === 'expired') { %>
          <span class="tag tag-danger">过期</span>
        <% } else { %>
          <span class="tag tag-default">未知</span>
        <% } %>
        </span>
        <button class="btn btn-sm btn-secondary" onclick="checkCookie()" id="checkCookieBtn" style="margin-left: 8px;">检测Cookie</button>
        <span id="checkMsg" style="margin-left: 8px; font-size: 12px;"></span>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="color: #666; font-size: 13px;">会员：</span>
        <span id="vipInfo">
        <% if (account.vip_type === 'svip' || account.vip_type === 'vip') { %>
          <span class="tag tag-warning"><%= account.vip_type.toUpperCase() %></span>
        <% } else { %>
          <%= account.vip_type || '--' %>
        <% } %>
        </span>
        <% if (account.vip_expire_date) { %>
          <span style="margin-left: 8px; font-size: 12px; color: #999;">到期 <%= account.vip_expire_date %></span>
        <% } %>
        <button class="btn btn-sm btn-secondary" onclick="fetchVip()" id="fetchVipBtn" style="margin-left: 8px;">抓取账号信息</button>
        <button class="btn btn-sm btn-secondary" onclick="scanTest(<%= account.id %>, '<%= account.nickname %>')" id="scanTestBtn" style="margin-left: 8px;">扫码测试</button>
      </div>
      <div style="margin-bottom: 12px;">
        <span style="color: #666; font-size: 13px;">最后更新：</span>
        <span><%= account.cookie_updated_at || '--' %></span>
      </div>

      <form id="cookieForm" style="border-top: 1px solid #E8E8E8; padding-top: 12px;">
        <div class="form-group">
          <label>更新 Cookie</label>
          <textarea name="cookie_text" class="form-control" rows="4" placeholder="粘贴新的 Cookie 字符串..." style="resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn btn-secondary btn-sm">更新 Cookie</button>
        <span id="cookieMsg" style="margin-left: 12px; font-size: 13px;"></span>
      </form>
    </div>

    <!-- 使用记录 -->
    <div class="card">
      <div class="card-title">最近使用记录</div>
      <% if (logs.length === 0) { %>
        <p style="color: #999; font-size: 13px;">暂无使用记录</p>
      <% } else { %>
        <table>
          <thead>
            <tr><th>时间</th><th>操作</th><th>IP</th></tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log) { %>
            <tr>
              <td><%= log.created_at ? log.created_at.slice(0, 16) : '--' %></td>
              <td><%= log.action %></td>
              <td><%= log.ip_address || '--' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <!-- 删除 -->
    <div class="card" style="border: 1px solid #FFE6E6;">
      <div class="card-title" style="color: #FF4D4F;">危险操作</div>
      <p style="color: #999; font-size: 13px; margin-bottom: 12px;">删除后该账号将不再出现在列表中，关联的分享链接也会失效。</p>
      <button class="btn btn-danger" onclick="deleteAccount(<%= account.id %>)">删除此账号</button>
    </div>
  </div>

</div>


<!-- ======== 扫码测试取景框 ======== -->
<div class="scan-test-overlay" id="scanTestOverlay">
  <div class="scan-test-topbar">
    <span class="title">扫码测试登录</span>
    <button class="close-btn" onclick="closeScanTest()">&times;</button>
  </div>
  <div class="scan-test-viewport" id="scanTestViewport">
    <video id="scanTestVideo" autoplay playsinline></video>
    <canvas id="scanTestCanvas" style="display:none;"></canvas>
    <div class="scan-test-corner scan-test-corner-tl"></div>
    <div class="scan-test-corner scan-test-corner-tr"></div>
    <div class="scan-test-corner scan-test-corner-bl"></div>
    <div class="scan-test-corner scan-test-corner-br"></div>
    <div class="scan-test-line" id="scanTestLine"></div>
  </div>
  <div class="scan-test-status" id="scanTestStatus">正在启动摄像头...</div>
  <div class="scan-test-actions" id="scanTestActions">
    <div class="scan-test-hint" id="scanTestHint">
      <div class="hint-icon">&#128269;</div>
      <div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div>
    </div>
  </div>
</div>

<script>
var fullCookie = <%- JSON.stringify(cookieFull || '') %>;

function copyFullCookie() {
  if (!fullCookie) return;
  navigator.clipboard.writeText(fullCookie).then(function() {
    var el = document.getElementById('cookieCopyMsg');
    el.textContent = '已复制';
    el.style.color = '#52C41A';
    setTimeout(function() { el.textContent = ''; }, 1500);
  }).catch(function() {
    prompt('手动复制 Cookie:', fullCookie);
  });
}

document.getElementById('editForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const form = e.target;
  const msg = document.getElementById('editMsg');
  const body = {
    nickname: form.nickname.value,
    phone: form.phone.value,
    vip_type: form.vip_type.value,
    vip_expire_date: form.vip_expire_date.value,
    notes: form.notes.value,
  };
  const res = await fetch('/admin/api/accounts/<%= account.id %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  const data = await res.json();
  msg.textContent = data.message;
  msg.style.color = data.success ? '#52C41A' : '#FF4D4F';
});

document.getElementById('cookieForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const msg = document.getElementById('cookieMsg');
  const cookieText = this.cookie_text.value;
  if (!cookieText) { msg.textContent = '请输入 Cookie'; msg.style.color = '#FF4D4F'; return; }

  const res = await fetch('/admin/api/accounts/<%= account.id %>/cookie', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ cookie_text: cookieText })
  });
  const data = await res.json();
  msg.textContent = data.message;
  msg.style.color = data.success ? '#52C41A' : '#FF4D4F';
  if (data.success) {
    this.reset();
    setTimeout(function() { location.reload(); }, 800);
  }
});

async function checkCookie() {
  const msg = document.getElementById('checkMsg');
  const btn = document.getElementById('checkCookieBtn');
  btn.disabled = true; btn.textContent = '检测中...';
  msg.textContent = '';
  try {
    const res = await fetch('/admin/api/accounts/<%= account.id %>/check-cookie', { method: 'POST' });
    const data = await res.json();
    if (data.success && data.result) {
      const r = data.result;
      if (r.valid) {
        msg.textContent = r.username ? (r.username + ' · ' + (r.vipType ? r.vipType.toUpperCase() : '')) : '有效';
        msg.style.color = '#52C41A';
        document.getElementById('cookieStatus').innerHTML = '<span class="tag tag-success">有效</span>';
      } else {
        msg.textContent = r.raw || '已过期';
        msg.style.color = '#FF4D4F';
        document.getElementById('cookieStatus').innerHTML = '<span class="tag tag-danger">过期</span>';
      }
    } else {
      msg.textContent = data.message || '检测失败';
      msg.style.color = '#FF4D4F';
    }
  } catch(e) {
    msg.textContent = '网络错误';
    msg.style.color = '#FF4D4F';
  }
  btn.disabled = false; btn.textContent = '检测Cookie';
}

async function fetchVip() {
  const msg = document.getElementById('checkMsg');
  const btn = document.getElementById('fetchVipBtn');
  btn.disabled = true; btn.textContent = '抓取中...';
  try {
    const res = await fetch('/admin/api/accounts/<%= account.id %>/check-cookie', { method: 'POST' });
    const data = await res.json();
    if (data.success && data.result) {
      const r = data.result;
      if (r.vipType) {
        msg.textContent = r.vipType.toUpperCase() + (r.expireDate ? ' 到期 ' + r.expireDate : '');
        msg.style.color = '#52C41A';
        document.querySelector('select[name="vip_type"]').value = r.vipType;
        document.getElementById('vipInfo').innerHTML = '<span class="tag tag-warning">' + r.vipType.toUpperCase() + '</span>';
      } else {
        // 明确非会员，清除旧状态
        msg.textContent = r.expireDate ? '会员已过期 (' + r.expireDate + ')' : '普通用户';
        msg.style.color = '#999';
        document.querySelector('select[name="vip_type"]').value = 'normal';
        document.getElementById('vipInfo').innerHTML = '<span style="color:#999;">普通用户</span>';
      }
      if (r.expireDate) {
        document.querySelector('input[name="vip_expire_date"]').value = r.expireDate;
      }
      if (r.username) {
        document.querySelector('input[name="nickname"]').value = r.username;
      }
    } else {
      msg.textContent = data.message || '抓取失败';
      msg.style.color = '#FF4D4F';
    }
  } catch(e) {
    msg.textContent = '网络错误';
    msg.style.color = '#FF4D4F';
  }
  btn.disabled = false; btn.textContent = '抓取账号信息';
}

async function deleteAccount(id) {
  if (!confirm('确定要永久删除此账号吗？此操作不可恢复。')) return;
  const res = await fetch('/admin/api/accounts/' + id + '/delete', { method: 'POST' });
  const data = await res.json();
  if (data.success) {
    location.href = '/admin/accounts';
  } else {
    alert(data.message);
  }
}

// ======== 扫码测试登录 ========
var scanTestStream = null;
var scanTestTimer = null;
var scanTestCapturedQR = '';
var scanTestAccountId = null;
var scanTestAccountName = '';
var scanTestConfirming = false;

async function scanTest(id, nickname) {
  scanTestAccountId = id;
  scanTestAccountName = nickname;
  scanTestCapturedQR = '';
  scanTestConfirming = false;

  var overlay = document.getElementById('scanTestOverlay');
  overlay.classList.add('show');
  document.getElementById('scanTestStatus').textContent = '正在启动摄像头...';
  document.getElementById('scanTestHint').style.display = 'flex';
  document.getElementById('scanTestActions').innerHTML =
    '<div class="scan-test-hint" id="scanTestHint"><div class="hint-icon">&#128269;</div><div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div></div>';

  try {
    scanTestStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } }
    });
    var video = document.getElementById('scanTestVideo');
    video.srcObject = scanTestStream;
    await video.play();
    document.getElementById('scanTestStatus').textContent = '测试账号：' + nickname + ' — 请扫描二维码';
    scanTestLoop();
  } catch (err) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">摄像头启动失败</span><br><small style="color:#999;">请确保使用HTTPS访问并授予摄像头权限</small>';
  }
}

function scanTestLoop() {
  if (scanTestCapturedQR || scanTestConfirming || !document.getElementById('scanTestOverlay').classList.contains('show')) return;
  var video = document.getElementById('scanTestVideo');
  if (video.readyState < video.HAVE_ENOUGH_DATA) { scanTestTimer = requestAnimationFrame(scanTestLoop); return; }
  var canvas = document.getElementById('scanTestCanvas');
  var w = video.videoWidth || 640, h = video.videoHeight || 480;
  canvas.width = w; canvas.height = h;
  var ctx = canvas.getContext('2d');
  ctx.drawImage(video, 0, 0, w, h);
  var imageData = ctx.getImageData(0, 0, w, h);
  try {
    var code = jsQR(imageData.data, w, h, { inversionAttempts: 'dontInvert' });
    if (code && code.data) {
      scanTestCapturedQR = code.data;
      stopScanTestCamera();
      showScanTestConfirm();
      return;
    }
  } catch(e) {}
  scanTestTimer = requestAnimationFrame(scanTestLoop);
}

function stopScanTestCamera() {
  if (scanTestTimer) { cancelAnimationFrame(scanTestTimer); scanTestTimer = null; }
  if (scanTestStream) { scanTestStream.getTracks().forEach(function(t) { t.stop(); }); scanTestStream = null; }
}

function closeScanTest() {
  stopScanTestCamera();
  document.getElementById('scanTestOverlay').classList.remove('show');
  scanTestCapturedQR = '';
  scanTestConfirming = false;
  scanTestAccountId = null;
}

function showScanTestConfirm() {
  document.getElementById('scanTestStatus').innerHTML =
    '<span style="color:#52C41A;">已检测到二维码</span>';
  document.getElementById('scanTestActions').innerHTML =
    '<button class="confirm-btn" onclick="doScanTest()">确认测试登录</button>' +
    '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>';
}

async function doScanTest() {
  scanTestConfirming = true;
  document.getElementById('scanTestStatus').textContent = '正在测试登录...';
  document.getElementById('scanTestActions').innerHTML = '';

  var btn = document.getElementById('scanTestBtn');
  if (btn) { btn.disabled = true; btn.textContent = '测试中...'; }

  try {
    var res = await fetch('/admin/api/accounts/' + scanTestAccountId + '/scan-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ qrContent: scanTestCapturedQR })
    });
    var data = await res.json();

    if (data.success) {
      var extra = data.rotated
        ? '<br><small style="color:#FAAD14;">已自动切换至备用账号：' + data.usedAccount.nickname + '（' + (data.usedAccount.vipType === 'svip' ? 'SVIP' : data.usedAccount.vipType === 'vip' ? 'VIP' : '普通') + '）</small>'
        : '<br><small style="color:#52C41A;">账号「' + data.usedAccount.nickname + '」Cookie有效，登录正常</small>';
      document.getElementById('scanTestStatus').innerHTML =
        '<span style="color:#52C41A;font-size:16px;">登录成功！</span>' + extra;
      document.getElementById('scanTestActions').innerHTML =
        '<button class="retry-btn" onclick="resetScanTest()">再次测试</button>' +
        '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';

      // 更新 Cookie 状态显示
      document.getElementById('cookieStatus').innerHTML = '<span class="tag tag-success">有效</span>';
      if (data.usedAccount.vipType) {
        document.getElementById('vipInfo').innerHTML = '<span class="tag tag-warning">' + data.usedAccount.vipType.toUpperCase() + '</span>';
      }
    } else {
      document.getElementById('scanTestStatus').innerHTML =
        '<span style="color:#FF4D4F;">登录失败</span><br><small style="color:#999;">' + (data.message || '未知错误') + '</small>';
      document.getElementById('scanTestActions').innerHTML =
        '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>' +
        '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';
    }
  } catch (e) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">网络错误</span><br><small style="color:#999;">' + (e.message || e) + '</small>';
    document.getElementById('scanTestActions').innerHTML =
      '<button class="retry-btn" onclick="resetScanTest()">重新扫描</button>' +
      '<button class="retry-btn" onclick="closeScanTest()">关闭</button>';
  }
  scanTestConfirming = false;
  if (btn) { btn.disabled = false; btn.textContent = '扫码测试'; }
}

async function resetScanTest() {
  scanTestCapturedQR = '';
  scanTestConfirming = false;
  document.getElementById('scanTestStatus').textContent = '正在重新启动摄像头...';
  document.getElementById('scanTestActions').innerHTML =
    '<div class="scan-test-hint" id="scanTestHint"><div class="hint-icon">&#128269;</div><div class="hint-text">将 PC 端百度网盘<br>登录二维码对准取景框</div></div>';

  try {
    scanTestStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: 'environment', width: { ideal: 640 }, height: { ideal: 640 } }
    });
    var video = document.getElementById('scanTestVideo');
    video.srcObject = scanTestStream;
    await video.play();
    document.getElementById('scanTestStatus').textContent = '测试账号：' + scanTestAccountName + ' — 请扫描二维码';
    scanTestLoop();
  } catch (err) {
    document.getElementById('scanTestStatus').innerHTML =
      '<span style="color:#FF4D4F;">摄像头启动失败</span><br><small style="color:#999;">' + (err.message || err) + '</small>';
  }
}
</script>
